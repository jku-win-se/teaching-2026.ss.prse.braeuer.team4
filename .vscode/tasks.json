{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "maven: clean compile",
			"type": "shell",
			"command": "mvn",
			"args": [
				"clean",
				"compile",
				"-DskipTests"
			],
			"group": {
				"kind": "build",
				"isDefault": true
			},
			"problemMatcher": [
				"$java"
			],
			"isBackground": false
		},
		{
			"label": "maven: test TestMockScheduleService",
			"type": "shell",
			"command": "mvn",
			"args": [
				"-Dtest=TestMockScheduleService",
				"test"
			],
			"isBackground": false,
			"problemMatcher": [
				"$javac"
			],
			"group": "test"
		},
		{
			"label": "maven: test TestMockScheduleService rerun",
			"type": "shell",
			"command": "mvn",
			"args": [
				"-Dtest=TestMockScheduleService",
				"test"
			],
			"isBackground": false,
			"problemMatcher": [
				"$javac"
			],
			"group": "test"
		}
	]
}