classDiagram

class User {
  +String id
  +String email
  +String passwordHash
  +Role role
}

class Role {
  <<enumeration>>
  OWNER
  MEMBER
}

class Session {
  +String id
  +DateTime createdAt
  +DateTime expiresAt
  +boolean active
  +terminate()
}

class Room {
  +String id
  +String name
  +rename(newName)
}

class Device {
  <<abstract>>
  +String id
  +String name
  +rename(newName)
}

class SwitchDevice {
  +boolean isOn
  +turnOn()
  +turnOff()
}

class DimmerDevice {
  +int brightness
  +setBrightness(value)
}

class ThermostatDevice {
  +double targetTemperature
  +setTargetTemperature(value)
}

class CoverDevice {
  +boolean open
  +open()
  +close()
}

class SensorDevice {
  +double currentValue
  +setCurrentValue(value)
}

User --> Role
User "1" --> "0..*" Session : owns
Room "1" --> "0..*" Device : organizes by location

Device <|-- SwitchDevice
Device <|-- DimmerDevice
Device <|-- ThermostatDevice
Device <|-- CoverDevice
Device <|-- SensorDevice