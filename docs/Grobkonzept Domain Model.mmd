classDiagram

class Room {
  +String id
  +String name
  +rename(newName)
}

class Device {
  <<abstract>>
  +String id
  +String name
  +rename(newName)
}
class SwitchDevice {
  +boolean isOn
  +turnOn()
  +turnOff()
}

class DimmerDevice {
  +int brightness
  +setBrightness(value)
}

class ThermostatDevice {
  +double targetTemperature
  +setTargetTemperature(value)
}

class CoverDevice {
  +boolean open
  +open()
  +close()
}

class SensorDevice {
  +double currentValue
  +setCurrentValue(value)
}

Device <|-- SwitchDevice
Device <|-- DimmerDevice
Device <|-- ThermostatDevice
Device <|-- CoverDevice
Device <|-- SensorDevice


Room "1" --> "0..*" Device :  organizes by location


class User {
  +String id
  +String email
  +String passwordHash
  +Role role
}

class Role {
  <<enumeration>>
  OWNER
  MEMBER
}

User --> Role

class Session {
  +String id
  +DateTime createdAt  
  +DateTime expiresAt
  +boolean active
  +terminate()
}

User "1" --> "0..*" Session : owns

class LogEntry {
  +String id
  +DateTime timestamp
  +String actor
  +String changeDescription
}

Device "1" <-- "0..*" LogEntry : recorded for

class Schedule {
  +String id
  +String name
  +String recurrencePattern
  +boolean enabled
}

class Rule {
  +String id
  +String name
  +boolean enabled
}

class Trigger {
  <<abstract>>
}
class TimeTrigger {
  +String timePattern
}

class ThresholdTrigger {
  +String operator
  +double threshold
}

class EventTrigger {
  +String eventType
}
Trigger <|-- TimeTrigger
Trigger <|-- ThresholdTrigger
Trigger <|-- EventTrigger

class Action {
  +String id
  +String actionType
  +String targetValue
}
Rule "1" --> "1" Trigger : evaluates
Rule "1" --> "1" Action : executes
Schedule "1" --> "1" Action : executes
Action --> Device : targets

class Notification {
  +String id
  +String message
  +NotificationType type
  +boolean read
  +markAsRead()
}
class NotificationType {
  <<enumeration>>
  SUCCESS
  FAILURE
}

Rule "1" --> "0..*" Notification : produces
Notification --> NotificationType


class SchedulingConflict {
  +String id
  +DateTime detectedAt
  +String description
}

SchedulingConflict --> Device : concerns
SchedulingConflict --> Rule : ruleA
SchedulingConflict --> Rule : ruleB

class Scene {
  +String id
  +String name
  +activate()
}

class SceneItem {
  +String id
  +String targetValue
}

Scene "1" --> "1..*" SceneItem : contains
SceneItem --> Device : targets

