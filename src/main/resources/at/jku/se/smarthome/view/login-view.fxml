<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="at.jku.se.smarthome.controller.LoginController"
            stylesheets="@styles.css">
    
    <center>
        <VBox alignment="CENTER" spacing="20" style="-fx-padding: 40;">
            <Label text="Smart Home Orchestrator" style="-fx-font-size: 28; -fx-text-fill: #2c3e50; -fx-font-weight: bold;"/>
            
            <VBox spacing="10" style="-fx-max-width: 400;">
                <Label text="Email" style="-fx-font-size: 14; -fx-text-fill: #34495e;"/>
                <TextField fx:id="emailField" promptText="Enter your email"
                           style="-fx-padding: 10; -fx-font-size: 12;"/>
                
                <Label text="Password" style="-fx-font-size: 14; -fx-text-fill: #34495e;"/>
                <PasswordField fx:id="passwordField" promptText="Enter your password"
                               onAction="#handleLogin"
                               style="-fx-padding: 10; -fx-font-size: 12;"/>
                
                <Button fx:id="loginButton" text="Login" styleClass="btn-primary"
                        onAction="#handleLogin" style="-fx-padding: 12; -fx-font-size: 14;"/>
                
                <VBox alignment="CENTER" spacing="5" style="-fx-padding-top: 10;">
                    <Label text="No account?" style="-fx-font-size: 12; -fx-text-fill: #7f8c8d;"/>
                    <Label text="Register" style="-fx-font-size: 12; -fx-text-fill: #3498db; -fx-underline: true; -fx-cursor: hand;"
                           onMouseClicked="#handleRegisterClick"/>
                </VBox>
            </VBox>
            
            <Label fx:id="errorLabel" text="" style="-fx-text-fill: #e74c3c; -fx-font-size: 12;"/>
        </VBox>
    </center>
</BorderPane>
